<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet author="keycloak" id="26.7.0-event-hook-target-table">
        <preConditions onFail="MARK_RAN" onSqlOutput="TEST">
            <not>
                <tableExists tableName="EVENT_HOOK_TARGET"/>
            </not>
        </preConditions>
        <createTable tableName="EVENT_HOOK_TARGET">
            <column name="ID" type="VARCHAR(36)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="CONSTRAINT_EVENT_HOOK_TARGET"/>
            </column>
            <column name="REALM_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="TYPE" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="ENABLED" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="SETTINGS_JSON" type="CLOB"/>
        </createTable>
    </changeSet>

    <changeSet author="keycloak" id="26.7.0-event-hook-message-table">
        <preConditions onFail="MARK_RAN" onSqlOutput="TEST">
            <not>
                <tableExists tableName="EVENT_HOOK_MESSAGE"/>
            </not>
        </preConditions>
        <createTable tableName="EVENT_HOOK_MESSAGE">
            <column name="ID" type="VARCHAR(36)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="CONSTRAINT_EVENT_HOOK_MESSAGE"/>
            </column>
            <column name="REALM_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="TARGET_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="EXECUTION_ID" type="VARCHAR(36)"/>
            <column name="EXECUTION_BATCH" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="SOURCE_TYPE" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="SOURCE_EVENT_ID" type="VARCHAR(255)"/>
            <column name="STATUS" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="PAYLOAD_JSON" type="CLOB"/>
            <column name="ATTEMPT_COUNT" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="NEXT_ATTEMPT_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="EXECUTION_STARTED_AT" type="BIGINT"/>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="LAST_ERROR" type="VARCHAR(2048)"/>
            <column name="IS_TEST" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet author="keycloak" id="26.7.0-event-hook-log-table">
        <preConditions onFail="MARK_RAN" onSqlOutput="TEST">
            <not>
                <tableExists tableName="EVENT_HOOK_LOG"/>
            </not>
        </preConditions>
        <createTable tableName="EVENT_HOOK_LOG">
            <column name="ID" type="VARCHAR(36)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="CONSTRAINT_EVENT_HOOK_LOG"/>
            </column>
            <column name="EXECUTION_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="STATUS" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="ATTEMPT_NUMBER" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="STATUS_CODE" type="VARCHAR(255)"/>
            <column name="DURATION_MS" type="BIGINT"/>
            <column name="DETAILS" type="VARCHAR(2048)"/>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

