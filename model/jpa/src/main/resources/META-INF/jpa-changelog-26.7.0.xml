    <changeSet author="keycloak" id="26.7.0-event-hook-target-table">
        <preConditions onFail="MARK_RAN" onSqlOutput="TEST">
            <not>
                <tableExists tableName="EVENT_HOOK_TARGET"/>
            </not>
        </preConditions>
        <createTable tableName="EVENT_HOOK_TARGET">
            <column name="ID" type="VARCHAR(36)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="CONSTRAINT_EVENT_HOOK_TARGET"/>
            </column>
            <column name="REALM_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="TYPE" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="ENABLED" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="CREATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="UPDATED_AT" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="SETTINGS_JSON" type="CLOB"/>
        </createTable>
    </changeSet>

