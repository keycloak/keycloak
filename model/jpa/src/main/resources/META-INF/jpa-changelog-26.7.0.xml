            <tableExists tableName="EVENT_HOOK_TARGET"/>
        </preConditions>
        <addColumn tableName="EVENT_HOOK_TARGET">
            <column name="AUTO_DISABLED_UNTIL" type="BIGINT"/>
        </addColumn>
        <addColumn tableName="EVENT_HOOK_TARGET">
            <column name="AUTO_DISABLED_REASON" type="VARCHAR(255)"/>
        </addColumn>
        <addColumn tableName="EVENT_HOOK_TARGET">
