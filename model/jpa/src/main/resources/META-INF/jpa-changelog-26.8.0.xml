<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

    <changeSet author="keycloak" id="26.8.0-invitation-attributes-table">
        <preConditions onFail="MARK_RAN" onSqlOutput="TEST">
            <not>
                <tableExists schemaName="${database.defaultSchemaName}"
                             tableName="ORG_INVITATION_ATTRIBUTE"/>
            </not>
        </preConditions>

        <createTable tableName="ORG_INVITATION_ATTRIBUTE">
            <column name="ID" type="VARCHAR(36)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="CONSTRAINT_ORG_INV_ATTR"/>
            </column>
            <column name="INVITATION_ID" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="NAME" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="VALUE" type="NVARCHAR(255)"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="ORG_INVITATION_ATTRIBUTE"
                                 baseColumnNames="INVITATION_ID"
                                 constraintName="FK_ORG_INV_ATTR_INV"
                                 referencedTableName="ORG_INVITATION"
                                 referencedColumnNames="ID"
                                 onDelete="CASCADE"/>

        <createIndex indexName="IDX_ORG_INV_ATTR_INV_ID" tableName="ORG_INVITATION_ATTRIBUTE">
            <column name="INVITATION_ID"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
