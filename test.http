    "urn:ietf:params:scim:api:messages:2.0:PatchOp"
  ]
}

### SCIM GET User
GET http://localhost:8180/realms/scim/scim/organizations/keycloak/v2/Users
Content-Type: application/json
Authorization: Bearer {{auth_token}}

### SCIM GET Organization Members
GET http://localhost:8180/realms/scim/scim/organizations/keycloak/v2/Users
Content-Type: application/json
Authorization: Bearer {{auth_token}}

