### SCIM Patch User
PATCH http://localhost:8180/realms/scim/scim/v2/Users/c0093fc6-ff58-4fc1-b21f-e1a3a079ad92
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "Operations": [
    {
      "op": "replace",
      "path": "emails[type eq \"work\"].value",
      "value": "eduardo@aufderhar.info"
    },
    {
      "op": "replace",
      "path": "emails[type eq \"work\"].primary",
      "value": true
    },
    {
      "op": "replace",
      "value": {
        "active": true,
        "displayName": "TJDKQZWRZLMY",
        "title": "XSKHHDCYQTET",
        "preferredLanguage": "gl-ES",
        "name.givenName": "Amanda",
