<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!--
    Partition-friendly tweaks to SSF_EVENT. None of the changes
    required for non-partitioned deployments — the schema works exactly the
    same as before. They unlock declarative table partitioning on
    PostgreSQL / MySQL / Oracle for operators that want it (see
    keycloak-notes/ssf/operations/ssf-outbox-partitioning.md for the
    operator recipe).

    Why these specific changes? PostgreSQL (and MySQL >=8) declarative
    partitioning requires the partition key to be a member of the table's
    PRIMARY KEY and of every UNIQUE constraint on the table. The default
    schema put the PK on `(id)` and the dedup unique on `(client_id, jti)`,
    neither of which includes a partition-friendly column. Promoting both
    to include `created_at` is backwards-compatible (`id` remains UUID-
    unique on its own; the explicit dedup lookup in
    `SsfPendingEventStore.enqueuePending*` still does the (client_id, jti)
    check before insert) and does not break dialects that do not partition
    (H2, older Oracle).
-->
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet author="keycloak" id="ssf-1.0.1-outbox-partition-friendly-keys">

        <!--
            Promote PK from (id) to (id, created_at). `id` is still UUID
            and effectively unique on its own; created_at is added solely
            so PostgreSQL `PARTITION BY RANGE (created_at)` can be applied
            without further DDL. Same constraint name so non-partitioned
            deployments see no observable change.
        -->
        <dropPrimaryKey tableName="SSF_EVENT"
                        constraintName="PK_SSF_EVENT"/>
        <addPrimaryKey tableName="SSF_EVENT"
                       columnNames="ID, CREATED_AT"
                       constraintName="PK_SSF_EVENT"/>

        <!--
            Same rationale for the dedup unique constraint. The application-
            level dedup is the explicit findByClientAndJti lookup in
            SsfPendingEventStore.enqueuePending*; the DB-level unique is the
            safety net. Adding created_at lets the safety-net constraint
            survive partitioning at the cost of theoretically allowing the
            same (client_id, jti) twice if their created_at differ — which
            the application code never does.
        -->
        <dropUniqueConstraint tableName="SSF_EVENT"
                              constraintName="UC_SSF_EVENT_CLIENT_JTI"/>
        <addUniqueConstraint tableName="SSF_EVENT"
                             columnNames="CLIENT_ID, JTI, CREATED_AT"
                             constraintName="UC_SSF_EVENT_CLIENT_JTI"/>

    </changeSet>

    <changeSet author="keycloak" id="ssf-1.0.1-outbox-drain-partial-index"
               dbms="postgresql">

        <!--
            PostgreSQL-only partial index that matches the drainer's hot
            query exactly:
              WHERE status = 'PENDING'
                AND delivery_method = 'PUSH'
              ORDER BY next_attempt_at ASC

            Once DELIVERED rows accumulate (audit retention, anything more
            than minutes), the existing IDX_SSF_EVENT_DRAIN grows linearly
            with the table while the hot working set stays tiny. The partial
            index is bounded by the actual PENDING+PUSH cardinality —
            typically <1% of the table on healthy deployments. The full
            IDX_SSF_EVENT_DRAIN index from ssf-changelog-1.0.0 is kept in
            place: it covers other STATUS / DELIVERY_METHOD combinations
            (POLL when that ships, DEAD_LETTER reconciliation queries) and
            stays the only available index on dialects without partial-index
            support.

            CREATE INDEX IF NOT EXISTS keeps the changeset safe to re-run
            against environments that may have applied the index manually.
        -->
        <sql>
            CREATE INDEX IF NOT EXISTS IDX_SSF_EVENT_DRAIN_HOT
                ON SSF_EVENT (NEXT_ATTEMPT_AT)
                WHERE STATUS = 'PENDING' AND DELIVERY_METHOD = 'PUSH'
        </sql>
        <rollback>
            DROP INDEX IF EXISTS IDX_SSF_EVENT_DRAIN_HOT
        </rollback>

    </changeSet>

</databaseChangeLog>
