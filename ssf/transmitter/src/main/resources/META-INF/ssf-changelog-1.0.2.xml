<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!--
    Renames the SSF outbox table and its surrounding constraints/indexes
    from the original {@code SSF_PENDING_*} naming to a shorter
    {@code SSF_EVENT*} prefix that matches the renamed JPA entity
    (org.keycloak.ssf.transmitter.outbox.SsfEventEntity, formerly
    SsfPendingEventEntity).

    No structural change — column set, primary-key column membership
    ((ID, CREATED_AT) after 1.0.1), unique-constraint membership
    ((CLIENT_ID, JTI, CREATED_AT)), and index column lists are
    unchanged. Application-level behaviour is identical; only the
    object names move.

    Changeset ordering follows Liquibase best practice: rather than
    editing the 1.0.0 / 1.0.1 files in place (which would break the
    MD5SUM check on every deployment that already applied them), the
    rename lives in this fresh changelog. New deployments progress
    1.0.0 → 1.0.1 → 1.0.2 and arrive at the new names; existing
    1.0.1-applied deployments only run 1.0.2 on next startup.
-->
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet author="keycloak" id="ssf-1.0.2-outbox-rename-table-and-constraints">

        <!-- Rename the table itself first so subsequent constraint/index
             operations can reference the new name. -->
        <renameTable oldTableName="SSF_PENDING_EVENT"
                     newTableName="SSF_EVENT"/>

        <!-- Rename the primary key. Liquibase has no <renamePrimaryKey>,
             so drop + re-add with the same column set ((ID, CREATED_AT)
             after the 1.0.1 promotion) and the new constraint name. -->
        <dropPrimaryKey tableName="SSF_EVENT"
                        constraintName="PK_SSF_PENDING_EVENT"/>
        <addPrimaryKey tableName="SSF_EVENT"
                       columnNames="ID, CREATED_AT"
                       constraintName="PK_SSF_EVENT"/>

        <!-- Rename the dedup unique constraint. Same drop + re-add
             pattern, same column set ((CLIENT_ID, JTI, CREATED_AT)
             after the 1.0.1 promotion), new constraint name. -->
        <dropUniqueConstraint tableName="SSF_EVENT"
                              constraintName="UC_SSF_PENDING_CLIENT_JTI"/>
        <addUniqueConstraint tableName="SSF_EVENT"
                             columnNames="CLIENT_ID, JTI, CREATED_AT"
                             constraintName="UC_SSF_EVENT_CLIENT_JTI"/>

        <!-- Rename the three indexes from 1.0.0. Liquibase doesn't have
             a portable <renameIndex> in the version Keycloak ships with,
             so we drop + recreate. Column lists must match 1.0.0
             exactly so query plans the planner already cached for the
             old index name still apply against the new one. -->
        <dropIndex tableName="SSF_EVENT" indexName="IDX_SSF_PENDING_DRAIN"/>
        <createIndex tableName="SSF_EVENT" indexName="IDX_SSF_EVENT_DRAIN">
            <column name="STATUS"/>
            <column name="DELIVERY_METHOD"/>
            <column name="NEXT_ATTEMPT_AT"/>
        </createIndex>

        <dropIndex tableName="SSF_EVENT" indexName="IDX_SSF_PENDING_CLIENT"/>
        <createIndex tableName="SSF_EVENT" indexName="IDX_SSF_EVENT_CLIENT">
            <column name="CLIENT_ID"/>
            <column name="STATUS"/>
        </createIndex>

        <dropIndex tableName="SSF_EVENT" indexName="IDX_SSF_PENDING_REALM"/>
        <createIndex tableName="SSF_EVENT" indexName="IDX_SSF_EVENT_REALM">
            <column name="REALM_ID"/>
            <column name="STATUS"/>
        </createIndex>

    </changeSet>

    <!--
        PostgreSQL-only follow-up for the partial drainer-hot index from
        ssf-changelog-1.0.1. Liquibase's <renameIndex> works on Postgres,
        but the index was created via a raw <sql> CREATE INDEX (because
        Liquibase doesn't model partial indexes natively), so we mirror
        that here: drop the old name and recreate under the new name.
        The IF EXISTS / IF NOT EXISTS guards keep the changeset safe to
        re-run against environments that may have applied either form
        manually.
    -->
    <changeSet author="keycloak" id="ssf-1.0.2-outbox-rename-drain-partial-index"
               dbms="postgresql">
        <sql>
            DROP INDEX IF EXISTS IDX_SSF_PENDING_DRAIN_HOT
        </sql>
        <sql>
            CREATE INDEX IF NOT EXISTS IDX_SSF_EVENT_DRAIN_HOT
                ON SSF_EVENT (NEXT_ATTEMPT_AT)
                WHERE STATUS = 'PENDING' AND DELIVERY_METHOD = 'PUSH'
        </sql>
        <rollback>
            DROP INDEX IF EXISTS IDX_SSF_EVENT_DRAIN_HOT;
            CREATE INDEX IF NOT EXISTS IDX_SSF_PENDING_DRAIN_HOT
                ON SSF_EVENT (NEXT_ATTEMPT_AT)
                WHERE STATUS = 'PENDING' AND DELIVERY_METHOD = 'PUSH'
        </rollback>
    </changeSet>

</databaseChangeLog>
